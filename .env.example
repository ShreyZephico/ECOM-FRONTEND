## Frontend (Vite) environment variables
#
# Copy to `.env.local` for local development.
#
# Note: Vite only exposes variables prefixed with `VITE_` to the browser.

# Base URL for the backend API (recommended: same-origin).
# In production, keep it as "/api" and configure your platform/proxy to route /api → backend.
VITE_STORE_API_BASE_URL=/api

# Publishable API key required by the backend.
VITE_STORE_PUBLISHABLE_API_KEY=pk_your_publishable_key_here

# Dev-only: where Vite should proxy /api, /store, /static during `npm run dev`.
VITE_DEV_PROXY_TARGET=http://localhost:9000

# Optional: deploy under a subpath (e.g. "/ringecom/"). For root deployments, keep "/".
VITE_BASE_PATH=/
